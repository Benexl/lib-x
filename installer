_install_lib_x() {
  local target_dest="$HOME/.local/bin/lib-x"
  mkdir -p "$(dirname "$target_dest")"

  if ! _get_release_asset "lib-x" "$target_dest" "binary" >"${target_dest}.tmp"; then
    _ui_print "Failed to download lib-x asset"
    exit 1
  fi

  mv "${target_dest}.tmp" "$target_dest"
  chmod +x "$target_dest"

  _ui_print "lib-x has been installed to $target_dest"
}

_lib_x() {
  readonly DEPENDENCIES="\
calibre - for managing and interacting with your book database (required)
jq - for parsing json responses (required)
fzf - default launcher for browsing and searching books (required)
rofi - alternative launcher; really cool great for keybinds (optional)
gum - terminal QoL components for prompts, confirmations, pagers (optional)
yazi - terminal file explorer for adding books (optional)
chafa - for rendering book cover previews in the terminal (optional)"

  readonly LANG_EXTENSIONS="\
es.lang - Spanish language extension
br.lang - Brazilian Portuguese language extension"

  readonly THEME_EXTENSIONS="\
catppuchin-mocha.theme - A catppuchin mocha inspired theme"

  readonly ASSETS="\
rofi themes - A collection of rofi themes optimized for lib-x"
}

installer() {
  _lib_x_default_config
  _installer_default_config
  _lib_x

  _ui_print "======================================================================================================="
  _ui_print "$CLI_HEADER"
  _ui_print "======================================================================================================="
  _ui_print "Welcome to the interactive $CLI_NAME installer! Lets get you settled in :)"
  _ui_print "======================================================================================================="

  # shellcheck disable=SC2155
  readonly CLI_LATEST_VERSION="$(_fetch "$CLI_VERSION_URL")"
  readonly LIB_X_RELEASE_TAG="$CLI_RELEASE_BASE/v$CLI_LATEST_VERSION"

  local missing_deps
  missing_deps="$(
    printf "%s\n" "$DEPENDENCIES" | while read -r dep; do
      if ! _dep_ch "$(printf "%s\n" "$dep" | awk -F ' - ' '{print $1}')"; then
        printf "%s\n" "$dep"
      fi
    done
  )"
  if [ -n "$missing_deps" ]; then
    printf "%s\n" "$missing_deps" | _ui_choose "There are some dependencies which have not been found. Select dependencies you would like to install" "multi" | awk -F ' - ' '{print $1}' | _install_deps
  fi

  if _ui_confirm "Would you like to change the default language (English)?" "no"; then
    printf "%s\n" "$LANG_EXTENSIONS" | _ui_choose "Select language extension to install" | awk -F ' - ' '{print $1}' | _install_extension_default_lang
  fi

  if _ui_confirm "Would you like to add other languages?" "no"; then
    printf "%s\n" "$LANG_EXTENSIONS" | _ui_choose "Select language extensions to install" "multi" | awk -F ' - ' '{print $1}' | _install_extension_lang
  fi

  if _ui_confirm "Would you like to change the default theme (Tokyo Night)?" "no"; then
    printf "%s\n" "$THEME_EXTENSIONS" | _ui_choose "Select theme extension to install" | awk -F ' - ' '{print $1}' | _install_extension_default_theme
  fi

  if _ui_confirm "Would you like to add other themes?" "no"; then
    printf "%s\n" "$THEME_EXTENSIONS" | _ui_choose "Select theme extensions to install" "multi" | awk -F ' - ' '{print $1}' | _install_extension_theme
  fi

  if _ui_confirm "Would you like to install external assets like rofi themes?" "yes"; then
    printf "%s\n" "$ASSETS" | _ui_choose "Select assets to install" "multi" | awk -F ' - ' '{print $1}' | _install_assets
    if [ -d "$LIB_X_CONFIG_DIR/rofi-themes" ]; then
      LIB_X_CONFIG_ROFI_THEME_MAIN="$LIB_X_CONFIG_DIR/rofi-themes/main.rasi"
      LIB_X_CONFIG_ROFI_THEME_PREVIEW="$LIB_X_CONFIG_DIR/rofi-themes/preview.rasi"
      LIB_X_CONFIG_ROFI_THEME_PROMPT="$LIB_X_CONFIG_DIR/rofi-themes/prompt.rasi"
      LIB_X_CONFIG_ROFI_THEME_CONFIRM="$LIB_X_CONFIG_DIR/rofi-themes/confirm.rasi"
      LIB_X_CONFIG_ROFI_THEME_PAGER="$LIB_X_CONFIG_DIR/rofi-themes/pager.rasi"
    fi
  fi

  if _ui_confirm "Would you like to interactively define your config?" "yes"; then
    LIB_X_CONFIG_CALIBRE_LIBRARY_PATH="$(_ui_prompt "CALIBRE_LIBRARY_PATH (Path to library)" "$LIB_X_CONFIG_CALIBRE_LIBRARY_PATH" "$LIB_X_CONFIG_CALIBRE_LIBRARY_PATH")"
    LIB_X_CONFIG_FILE_EXPLORER="$(_ui_prompt "FILE_EXPLORER (yazi/fzf)" "$LIB_X_CONFIG_FILE_EXPLORER" "$LIB_X_CONFIG_FILE_EXPLORER")"
    LIB_X_CONFIG_DISOWN_READING_PROCESS="$(_ui_prompt "DISOWN_READING_PROCESS (true/false)" "$LIB_X_CONFIG_DISOWN_READING_PROCESS" "$LIB_X_CONFIG_DISOWN_READING_PROCESS")"
    
    LIB_X_CONFIG_LAUNCHER="$(_ui_prompt "LAUNCHER (fzf/rofi/gum)" "$LIB_X_CONFIG_LAUNCHER" "$LIB_X_CONFIG_LAUNCHER")"
    LIB_X_CONFIG_ENABLE_PREVIEW="$(_ui_prompt "ENABLE_PREVIEW (true/false)" "$LIB_X_CONFIG_ENABLE_PREVIEW" "$LIB_X_CONFIG_ENABLE_PREVIEW")"
    LIB_X_CONFIG_ENABLE_PREVIEW_IMAGES="$(_ui_prompt "ENABLE_PREVIEW_IMAGES (true/false)" "$LIB_X_CONFIG_ENABLE_PREVIEW_IMAGES" "$LIB_X_CONFIG_ENABLE_PREVIEW_IMAGES")"

    LIB_X_CONFIG_IMAGE_RENDERER="$(_ui_prompt "IMAGE_RENDERER (chafa/icat/imgcat)" "$LIB_X_CONFIG_IMAGE_RENDERER" "$LIB_X_CONFIG_IMAGE_RENDERER")"
    LIB_X_CONFIG_EDITOR="$(_ui_prompt "EDITOR" "$LIB_X_CONFIG_EDITOR" "$LIB_X_CONFIG_EDITOR")"
  fi
  
  _print_lib_x_config >"$LIB_X_CONFIG_FILE"

  if _install_lib_x; then
    _ui_print "Installation complete ūü•≥! Enjoy $CLI_NAME!"
    if _ui_confirm "Would you like to open the github repo page?" "yes"; then
      _util_open "$CLI_REPO_URL"
    fi
  else
    _ui_print "Installation failed. Please try again or report the issue on GitHub."
  fi
}

installer
