__menu_miscellaneous_add_books_from_folder() {
  local books_path
  local custom_args=""

  if [ "$CONFIG_FILE_EXPLORER" = "yazi" ]; then
    yazi --cwd-file "$CLI_CACHE_DIR/books_path"
    books_path=$(cat "$CLI_CACHE_DIR/books_path")
  else
    books_path=$(find "$HOME" -type d | fzf)
  fi

  [ -z "$books_path" ] && return

  if ui_confirm "$TXT_MENU_MISC_PROMPT_CUSTOM_ARGS (default: calibredb add '$books_path')"; then
    custom_args="$(ui_prompt "$TXT_MENU_MISC_PROMPT_ENTER_ARGS")"
  fi

  if ui_confirm "$TXT_MENU_MISC_PROMPT_PROCEED"; then
    # shellcheck disable=SC2086
    calibredb add "$books_path" $custom_args
    _fetch_calibre_data "true"
  fi
}

__menu_miscellaneous_add_books() {
  local books_path
  local custom_args=""

  if [ "$CONFIG_FILE_EXPLORER" = "yazi" ]; then
    yazi --chooser-file "$CLI_CACHE_DIR/books_path"
    books_path=$(cat "$CLI_CACHE_DIR/books_path")
  else
    books_path=$(find "$HOME" -type f | fzf --multi)
  fi

  [ -z "$books_path" ] && return

  if ui_confirm "$TXT_MENU_MISC_PROMPT_CUSTOM_ARGS"; then
    custom_args="$(ui_prompt "$TXT_MENU_MISC_PROMPT_ENTER_ARGS")"
  fi

  if ui_confirm "$TXT_MENU_MISC_PROMPT_PROCEED"; then
    # shellcheck disable=SC2086
    printf '%s\n' "$books_path" | xargs -I {} calibredb add "{}" $custom_args
    _fetch_calibre_data "true"
  fi
}

__menu_miscellaneous_reload_data() {
  _fetch_calibre_data "true"
