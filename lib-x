  if ui_confirm "$TXT_MENU_BOOK_ACTIONS_REMOVE_CONFIRM $STATE_CURRENT_BOOK_TITLE?"; then
    if calibredb remove "$book_id"; then
      ui_notify "$TXT_MENU_BOOK_ACTIONS_REMOVED_SUCCESS"
    fi
