# ==============================================================================
# APP: cmdline parser
# ==============================================================================
_app_cmd_line_parser() {
  local shift_count
  while [ $# -gt 0 ]; do
    shift_count=1
    case "$1" in
    -h | --help) _app_usage ;;
    -v | --version) printf '%s v%s MIT Copyright © 2024 %s\n' "$CLI_NAME" "$CLI_VERSION" "$CLI_AUTHOR" && exit 0 ;;
    -U | --update) _app_update_check || printf '%s\n' "No updates found" && exit 1 ;;
    -e | --edit-config) __menu_main_edit_config && exit 0 ;;
    -E | --generate-desktop-entry) _app_generate_desktop_entry ;;
    -ce | --cmd-exit) CMD_EXIT=true ;;
    -bs | --book-skip) CMD_BOOK_RESULTS_SKIP=true ;;
    -be | --book-exit) CMD_EXIT_MENU=true ;;
    --config-write) _print_config >"$CLI_CONFIG_FILE" && exit 0 ;;
    --preview) CONFIG_ENABLE_PREVIEW=true ;;
    --no-preview) CONFIG_ENABLE_PREVIEW=false ;;
    --preview-images) CONFIG_ENABLE_PREVIEW_IMAGES=true ;;
    --no-preview-images) CONFIG_ENABLE_PREVIEW_IMAGES=false ;;
    -x | --extension)
      [ -n "$2" ] || _app_usage 1
      if [ "${2#/}" != "$2" ]; then
        . "$2"
      else
        . "$CLI_EXTENSIONS_DIR/$2"
      fi
      shift_count=2
      ;;
    -xargs | --extension-arguments)
      shift
      readonly CLI_EXTENSION_CMDLINE_ARGS="$*"
      return
      ;;
    -l | --launcher)
      [ -n "$2" ] || _app_usage 1
      CONFIG_LAUNCHER="$2"
      shift_count=2
      ;;
    -d | --disown-reading-process) CONFIG_DISOWN_READING_PROCESS="true" ;;
    -D | --no-disown-reading-process) CONFIG_DISOWN_READING_PROCESS="false" ;;
    --private) CONFIG_UPDATE_RECENT="false" ;;
    --rofi-theme-main | --rofi-theme)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_MAIN="$2"
      shift_count=2
      ;;
    --rofi-theme-preview)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_PREVIEW="$2"
      shift_count=2
      ;;
    --rofi-theme-prompt)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_PROMPT="$2"
      shift_count=2
      ;;
    --rofi-theme-confirm)
      [ -n "$2" ] || _app_usage 1
      CONFIG_ROFI_THEME_CONFIRM="$2"
      shift_count=2
      ;;

    # Direct menu shortcuts
    --reading-list) CMD_MAIN_ACTION="$TXT_MENU_MAIN_READING_LIST" ;;
    --recent) CMD_MAIN_ACTION="$TXT_MENU_MAIN_RECENT" ;;
    --paused) CMD_MAIN_ACTION="$TXT_MENU_MAIN_PAUSED" ;;
    --rereading) CMD_MAIN_ACTION="$TXT_MENU_MAIN_REREADING" ;;
    --planing) CMD_MAIN_ACTION="$TXT_MENU_MAIN_PLANING" ;;
    --completed) CMD_MAIN_ACTION="$TXT_MENU_MAIN_COMPLETED" ;;
    --docs) CMD_MAIN_ACTION="$TXT_MENU_MAIN_DOCS" ;;
    --dropped) CMD_MAIN_ACTION="$TXT_MENU_MAIN_DROPPED" ;;
    --all) CMD_MAIN_ACTION="$TXT_MENU_MAIN_ALL" ;;
    --random) CMD_MAIN_ACTION="$TXT_MENU_MAIN_RANDOM" ;;
    --misc | --miscellaneous) CMD_MAIN_ACTION="$TXT_MENU_MAIN_MISC" ;;

    # Book action shortcuts
    --read) CMD_BOOK_ACTION="$TXT_MENU_BOOK_ACTIONS_READ" ;;
    --edit-metadata) CMD_BOOK_ACTION="$TXT_MENU_BOOK_ACTIONS_EDIT_METADATA" ;;
    --remove-book) CMD_BOOK_ACTION="$TXT_MENU_BOOK_ACTIONS_REMOVE_BOOK" ;;

    # Arguments with parameters
    -g | --go-directly-to)
      if [ -z "$2" ]; then
        CMD_MAIN_ACTION="$(ui_prompt "Go to menu")"
        [ -n "$CMD_MAIN_ACTION" ] || _app_usage 1
      else
        CMD_MAIN_ACTION="$2"
        shift_count=2
      fi
      ;;
    -s | --search)
      if [ -z "$2" ]; then
        CMD_SEARCH="$(ui_prompt "Enter search query")"
        [ -n "$CMD_SEARCH" ] || _app_usage 1
      else
        CMD_SEARCH="$2"
        shift_count=2
      fi
      CMD_MAIN_ACTION="${CMD_GO_DIRECTLY_TO:-$TXT_MENU_MAIN_ALL}"
      ;;
    -S | --sort-by)
      if [ -z "$2" ]; then
        CMD_SORT_BY="$(ui_prompt "Sort by field (e.g., author, title, size)")"
        [ -n "$CMD_SORT_BY" ] || _app_usage 1
      else
        CMD_SORT_BY="$2"
        shift_count=2
      fi
      CMD_MAIN_ACTION="${CMD_GO_DIRECTLY_TO:-$TXT_MENU_MAIN_ALL}"
      ;;
    -r | --no-of-random-books)
      if [ -z "$2" ]; then
        CONFIG_NO_OF_RANDOM_BOOKS="$(ui_prompt "Number of random books")"
        [ -n "$CONFIG_NO_OF_RANDOM_BOOKS" ] || _app_usage 1
      else
        CONFIG_NO_OF_RANDOM_BOOKS="$2"
        shift_count=2
      fi
      CMD_MAIN_ACTION="${CMD_GO_DIRECTLY_TO:-$TXT_MENU_MAIN_RANDOM}"
      ;;

    # Subcommands
    completions)
      [ -n "$2" ] || _app_usage_completions 1
      case "$2" in
      -f | --fish) _app_completions_fish ;;
      -b | --bash) printf '%s\n' "Contribute to $CLI_NAME by writing bash completions" && exit 1 ;;
      -z | --zsh) printf '%s\n' "Contribute to $CLI_NAME by writing zsh completions" && exit 1 ;;
      -h | --help) _app_usage_completions ;;
      *) _app_usage_completions 1 ;;
      esac
      shift_count=2
      ;;
    *) _app_usage 1 ;;
    esac
    shift $shift_count
  done
}

# ==============================================================================
# APP
# ==============================================================================
main() {
  trap _app_runtime_clean_up EXIT INT TERM
  _load_config
  _app_cmd_line_parser "$@"
  _app_auto_update
  _app_core_dep_ch
  menu_main
}

main "$@"
