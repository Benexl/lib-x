# Calibre
# ==============================================================================
__fetch_calibre_db() {
  calibredb list --for-machine --fields all | tee "$CALIBRE_DB_JSON_FILE"
}

_fetch_calibre_db() {
  local calibre_library_current_timestamp

  calibre_library_current_timestamp="$(stat -c %Y "$CONFIG_CALIBRE_LIBRARY_PATH")"

  if ! [ -s "$CALIBRE_DB_JSON_FILE" ] || ! [ -s "$CALIBRE_LIBRARY_CACHED_TIMESTAMP_FILE" ] || [ "$(cat "$CALIBRE_LIBRARY_CACHED_TIMESTAMP_FILE")" -lt "$calibre_library_current_timestamp" ]; then
    if __fetch_calibre_db; then
      printf "%s" "$calibre_library_current_timestamp" >"$CALIBRE_LIBRARY_CACHED_TIMESTAMP_FILE"
    fi
  else
    cat "$CALIBRE_DB_JSON_FILE"
  fi
}

__fetch_calibre_categories() {
  calibredb list_categories --csv | tee "$CALIBRE_CATEGORIES_CSV_FILE"
}

_fetch_calibre_categories() {
  local calibre_library_current_timestamp

  calibre_library_current_timestamp="$(stat -c %Y "$CONFIG_CALIBRE_LIBRARY_PATH")"

  if [ "$(cat "$CALIBRE_LIBRARY_CACHED_TIMESTAMP_FILE")" -lt "$calibre_library_current_timestamp" ]; then
    __fetch_calibre_categories
  else
    cat "$CALIBRE_CATEGORIES_CSV_FILE"
  fi
}

# ==============================================================================
# Calibre: sort functions
# ==============================================================================
# shellcheck disable=SC2016
CALIBRE_SORT_JQ='
def sort_calibre_db(key)
  if $key == "title" then
    sort_by(.title | ascii_downcase)
  elif $key == "author" then
    sort_by(.authors[0] // "" | ascii_downcase)
  elif $key == "series" then
    sort_by(.series // "" | ascii_downcase)
  elif $key == "rating" then
    sort_by(.rating // 0)
  elif $key == "publisher" then
    sort_by(.publisher // "" | ascii_downcase)
  else .
  end;
'

# ==============================================================================
# Calibre: search functions
# ==============================================================================
_fetch_calibre_db_search_title() {
  _fetch_calibre_db | jq -r --arg title "$1" --arg sort_by "$2" "
    map(select(.title | test(\$title; 'i')))
    | $CALIBRE_SORT_JQ
    sort_calibre_db(.[\$sort_by])
  "
}

