# ==============================================================================
# User Lists
# ==============================================================================
_manage_user_list() {
  local list_name="$1"
  local action="$2"
  local title="$3"
  local file="$CLI_DBS_DIR/${list_name}"

  case "$action" in
  add)
    if grep -Fqx "$title" "$file" 2>/dev/null; then
      ui_notify_warning "Already in $list_name List"
    else
      ui_notify "Adding to $list_name list..."
      printf "%s\n" "$title" >>"$file"
    fi
    ;;
  remove)
    if grep -Fqx "$title" "$file" 2>/dev/null; then
      if ui_confirm "Are you sure you want to remove '$title' from $list_name List?"; then
        ui_notify "Removing from $list_name List..."
        grep -Fv "$title" "$file" >"${file}.tmp"
        mv "${file}.tmp" "$file"
      fi
    else
      ui_notify_warning "$title is not in your $list_name List"
    fi
    ;;
  esac
}

_update_recent() {
  local title="$1"
  local file="$CLI_DBS_DIR/recent"
  grep -Fv "$title" "$file" >"${file}.tmp" 2>/dev/null || true
  mv "${file}.tmp" "$file" 2>/dev/null || true
  printf "%s\n" "$title" >>"$file"
  tail -n "$CONFIG_NO_OF_RECENT" "$file" >"${file}.tmp"
  mv "${file}.tmp" "$file"
}

