__menu_book_actions_edit_metadata() {
  local field
  local book_id
  local val

  field="$(printf "author_sort\nauthors\ncomments\ncover\nid\nidentifiers\nlanguages\npubdate\npublisher\nrating\nseries\nseries_index\nsize\nsort\ntags\ntimestamp\ntitle\ntitle_sort" | ui_launcher "$TXT_MENU_BOOK_ACTIONS_PROMPT_FIELD")"

  [ -z "$field" ] && return

  book_id="$(printf '%s' "$STATE_CURRENT_BOOK_JSON" | jq -r '.id')"
  calibredb show_metadata "$book_id"

  val="$(ui_prompt "$TXT_MENU_BOOK_ACTIONS_PROMPT_NEW_VAL $field")"

  calibredb set_metadata "$book_id" --field "$field:$val"
  calibredb backup_metadata
  _fetch_calibre_data "true"
}

