__preview_fzf_create_shared_script() {
  if ! [ -s "$CLI_FZF_PREVIEW_SCRIPT" ]; then
    cat <<'EOF' >"$CLI_FZF_PREVIEW_SCRIPT"
#!/usr/bin/env sh
# ==============================================================================
# Shared script for fzf previews
# ==============================================================================

draw_divider() {
  ll=1
  while [ $ll -le $FZF_PREVIEW_COLUMNS ];do printf "${THEME_FZF_PREVIEW_DIVIDER}─${THEME_RESET}" ;ll=$(( ll + 1 ));done;
  echo
}

fzf_preview() {
  file=$1

  dim=${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}
  if [ "$dim" = "x" ]; then
    dim=$(stty size </dev/tty | awk "{print \$2 \"x\" \$1}")
  fi
  if ! [ "$CONFIG_IMAGE_RENDERER" = "icat" ] && [ -z "$KITTY_WINDOW_ID" ] && [ "$((FZF_PREVIEW_TOP + FZF_PREVIEW_LINES))" -eq "$(stty size </dev/tty | awk "{print \$1}")" ]; then
    dim=${FZF_PREVIEW_COLUMNS}x$((FZF_PREVIEW_LINES - 1))
  fi

  if [ "$CONFIG_IMAGE_RENDERER" = "icat" ] && [ -z "$GHOSTTY_BIN_DIR" ]; then
    if command -v kitten >/dev/null 2>&1; then
      kitten icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$file" | sed "\$d" | sed "$(printf "\$s/\$/\033[m/")"
    elif command -v icat >/dev/null 2>&1; then
      icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$file" | sed "\$d" | sed "$(printf "\$s/\$/\033[m/")"
    else
      kitty icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$file" | sed "\$d" | sed "$(printf "\$s/\$/\033[m/")"
    fi

  elif [ -n "$GHOSTTY_BIN_DIR" ]; then
    if command -v kitten >/dev/null 2>&1; then
      kitten icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$file" | sed "\$d" | sed "$(printf "\$s/\$/\033[m/")"
    elif command -v icat >/dev/null 2>&1; then
      icat --clear --transfer-mode=memory --unicode-placeholder --stdin=no --place="$dim@0x0" "$file" | sed "\$d" | sed "$(printf "\$s/\$/\033[m/")"
    else
      chafa -s "$dim" "$file"
    fi
  elif command -v chafa >/dev/null 2>&1; then
    case "$CLI_PLATFORM" in
    android) chafa -s "$dim" "$file" ;;
    windows) chafa -f sixel -s "$dim" "$file" ;;
    *) chafa -s "$dim" "$file" ;;
    esac
    echo

  elif command -v imgcat >/dev/null; then
    imgcat -W "${dim%%x*}" -H "${dim##*x}" "$file"

  else
    printf "%s" "$TXT_PREVIEW_INSTALL_VIEWER"
  fi
}
EOF
    chmod +x "$CLI_FZF_PREVIEW_SCRIPT"
  fi
}

__preview_fzf_generate_script_for_item() {
  local data_item="$1"
  local raw_title
  local cover
  local authors
  local tags
  local publisher
  local languages
  local rating
  local pubdate
  local comments
  local preview_script_path

  # Extract fields safely using jq and formatting them into shell variable declarations
  eval "$(printf "%s" "$data_item" | jq -r '
    [
      "raw_title=" + (.title // "" | sub("^[0-9]+ "; "") | @sh),
      "cover=" + (.cover // "" | @sh),
      "authors=" + (.authors // [] | join(", ") | @sh),
      "tags=" + (.tags // [] | join(", ") | @sh),
      "publisher=" + (.publisher // "Unknown" | @sh),
      "languages=" + (.languages // [] | join(", ") | @sh),
      "rating=" + (.rating // 0 | tostring | @sh),
      "pubdate=" + (.pubdate // "" | split("T")[0] | @sh),
      "comments=" + (.comments // "" | @sh)
    ] | join("\n")
  ')"

  preview_script_path="$CLI_PREVIEW_SCRIPTS_DIR/$(printf "%s" "$raw_title" | _util_generate_hash).sh"

  cat <<EOF >"$preview_script_path"
#!/usr/bin/env sh
# ==============================================================================
# Dynamically generated script for previewing $raw_title
# ==============================================================================

if [ -s "$CLI_FZF_PREVIEW_SCRIPT" ];then
  . "$CLI_FZF_PREVIEW_SCRIPT"
else
  exit 1
fi

if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && [ -n "$cover" ] && [ -s "$cover" ]; then
  fzf_preview "$cover" 2>/dev/null
fi

draw_divider

title="\$(printf '%s' "$raw_title" | fold -s -w "\$FZF_PREVIEW_COLUMNS")"
printf "${THEME_FZF_PREVIEW_TITLE}%s${THEME_RESET}\n" "\$title"

draw_divider

if [ -n "$authors" ];then
  authors="\$(printf '%s' "$authors" | fold -s -w "\$FZF_PREVIEW_COLUMNS")"
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_AUTHORS}: ${THEME_RESET}%s\n" "${THEME_FZF_PREVIEW_VALUE}\$authors${THEME_RESET}"
fi

if [ -n "$tags" ];then
  tags="\$(printf '%s' "$tags" | fold -s -w "\$FZF_PREVIEW_COLUMNS")"
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_TAGS}: ${THEME_RESET}%s\n" "${THEME_FZF_PREVIEW_VALUE}\$tags${THEME_RESET}"
fi

if [ -n "$languages" ];then
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_LANGUAGES}: ${THEME_RESET}%s\n" "${THEME_FZF_PREVIEW_VALUE}$languages${THEME_RESET}"
fi

if [ -n "$publisher" ] && [ "$publisher" != "Unknown" ];then
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_PUBLISHER}: ${THEME_RESET}%s\n" "${THEME_FZF_PREVIEW_VALUE}$publisher${THEME_RESET}"
fi

if [ -n "$pubdate" ];then
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_PUBDATE}: ${THEME_RESET}%s\n" "${THEME_FZF_PREVIEW_VALUE}$pubdate${THEME_RESET}"
fi

if [ "$rating" != "0" ];then
  printf "${THEME_FZF_PREVIEW_KEY}${THEME_BOLD}${TXT_FZF_PREVIEW_RATING}: ${THEME_RESET}%s / 10${THEME_RESET}\n" "${THEME_FZF_PREVIEW_VALUE}$rating${THEME_RESET}"
fi

draw_divider

if [ -n "$comments" ] && [ "$comments" != "null" ];then
  # strip basic HTML tags from comments if any
  printf "%s\n" "$comments" | sed -e 's/<[^>]*>//g' | fold -s -w "\$FZF_PREVIEW_COLUMNS"
fi
EOF
  chmod +x "$preview_script_path"
}

_preview_fzf_generate_script() {
  local data_to_preview="$1"
  __preview_fzf_create_shared_script

  printf "%s" "$data_to_preview" | jq -c '.[]' | while IFS= read -r data_item; do
    __preview_fzf_generate_script_for_item "$data_item"
  done
}

_preview_fzf() {
  # Pipe through stdin mapping the generated script to the title
  while IFS= read -r line; do
    if [ "$CONFIG_ENABLE_PREVIEW" = "true" ]; then
      local pure_title
      pure_title="$(printf '%s' "$line" | sed -E 's/^[0-9]+ //g')"
      printf '%s/%s.sh|%s\n' "$CLI_PREVIEW_SCRIPTS_DIR" "$(printf '%s' "$pure_title" | _util_generate_hash)" "$line"
    else
      printf '%s\n' "$line"
    fi
  done

  local data_to_preview="$1"

  if [ "$CONFIG_ENABLE_PREVIEW" = "true" ]; then
    # Generate all individual scripts in the background
    _preview_fzf_generate_script "$data_to_preview" &
  fi
}

preview_fzf() {
  _preview_fzf "$@"
}

_preview_rofi() {
  local data_to_preview="$1"
  local input_titles
  local input_count
  local output_count
  local others
  local output="$CLI_CURRENT_STATE_DIR/rofi-preview-output-$(date +%s)"

  if [ "$CONFIG_ENABLE_PREVIEW" = "true" ] && [ -n "$data_to_preview" ]; then
    input_titles="$(cat)"

    # Unlike yt-x, covers are local, so we just map Title + Cover path instantly
    printf "%s" "$data_to_preview" | jq --compact-output -r '.[]' | while IFS='\n' read -r entry; do
      local cover
      local title
      cover=$(printf '%s' "$entry" | jq -r '.cover')
      title=$(printf '%s' "$entry" | jq -r '.title')

      if [ -n "$cover" ] && [ "$cover" != "null" ] && [ -s "$cover" ]; then
        printf '%s\0icon\x1f%s\n' "$title" "$cover"
      else
        printf '%s\n' "$title"
      fi
    done >"$output"

    # Handle missing items
    input_count=$(printf "%s" "$input_titles" | wc -l)
    output_count=$(wc -l <"$output")
    others=$((input_count + 1 - output_count))

    cat "$output"
    if [ "$others" -gt 0 ]; then
      printf '%s\n' "$input_titles" | tail -n "$others"
    fi
  else
    cat
  fi
}

preview_rofi() {
  _preview_rofi "$@"
}

_preview() {
  case "$CONFIG_LAUNCHER" in
  fzf) preview_fzf "$@" ;;
  rofi) preview_rofi "$@" ;;
  *) cat ;;
  esac
}

preview() {
  _preview "$@"
}

